# ============================================================================
# laravel-rebel-channels — environment variables
# All optional: defaults live in config/rebel-channels.php.
# ============================================================================

# Per-number rate limit (cooldown): max sends per phone+channel within the window.
REBEL_CHANNELS_RL_MAX=5
REBEL_CHANNELS_RL_WINDOW=3600

# Anti toll-fraud / IRSF per-prefix velocity cap.
# LEN  = how many leading chars of the E.164 number form the bucket (3 -> "+39").
# MAX  = 0 disables the cap; set a positive number to enable the circuit breaker.
REBEL_CHANNELS_PREFIX_LEN=3
REBEL_CHANNELS_PREFIX_MAX=0
REBEL_CHANNELS_PREFIX_WINDOW=3600
